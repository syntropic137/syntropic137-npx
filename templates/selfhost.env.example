# =============================================================================
# Syntropic137 Self-Host Configuration
# =============================================================================
#
# Copy to .env and fill in your values.
# Only APP_ENVIRONMENT and an LLM provider key are required to get started.
#
# Generated secrets (run once during setup):
#   mkdir -p secrets
#   openssl rand -hex 32 > secrets/db-password.secret
#   openssl rand -hex 32 > secrets/redis-password.secret
#   openssl rand -hex 32 > secrets/minio-password.secret

# =============================================================================
# REQUIRED
# =============================================================================

APP_ENVIRONMENT=selfhost

# Image version — pin to a release tag for stability (e.g., v0.16.2)
SYN_VERSION=latest

# Anthropic API key — agents need an LLM provider.
# Get from: https://console.anthropic.com/settings/keys
# Not needed if CLAUDE_CODE_OAUTH_TOKEN is set.
ANTHROPIC_API_KEY=

# =============================================================================
# GITHUB APP (optional — enables PR triggers and code review)
# =============================================================================
# See: https://docs.syntropic137.dev/self-host/github-app
#
# Private key: place your .pem at ./secrets/github-app-private-key.pem
# It's mounted as a Docker secret automatically (tmpfs, never hits disk).
# SYN_GITHUB_APP_PRIVATE_KEY_FILE is set by docker-compose.syntropic137.yaml.

SYN_GITHUB_APP_ID=
SYN_GITHUB_APP_NAME=
SYN_GITHUB_WEBHOOK_SECRET=

# =============================================================================
# CLOUDFLARE TUNNEL (optional — enables webhooks and remote access)
# =============================================================================
# Without a tunnel the gateway binds to 127.0.0.1 only (local access).
# To enable: set COMPOSE_PROFILES=tunnel and provide your tunnel token.

COMPOSE_PROFILES=
CLOUDFLARE_TUNNEL_TOKEN=
SYN_PUBLIC_HOSTNAME=

# =============================================================================
# 1PASSWORD (optional — auto-resolves secrets at startup)
# =============================================================================

OP_SERVICE_ACCOUNT_TOKEN=

# =============================================================================
# MINIO (artifact storage)
# =============================================================================

MINIO_ROOT_USER=minioadmin

# =============================================================================
# AUTHENTICATION — Required for all deployments
# =============================================================================
# Basic auth password for the nginx gateway.
# WARNING: an empty password disables authentication entirely — do not expose
# via Cloudflare Tunnel or any public network without a password set.
# Auto-generated by the setup wizard. To rotate: npx @syntropic137/setup credentials rotate

SYN_API_USER=admin
SYN_API_PASSWORD=

# =============================================================================
# PORTS
# =============================================================================

SYN_GATEWAY_PORT=8137

# =============================================================================
# AGENT CREDENTIALS (alternative to ANTHROPIC_API_KEY)
# =============================================================================
# Claude Code OAuth token — if set, takes priority over ANTHROPIC_API_KEY.
# Obtained via Claude Code OAuth flow.

CLAUDE_CODE_OAUTH_TOKEN=

# =============================================================================
# RESOURCE LIMITS (optional — sensible defaults are set in the compose file)
# =============================================================================
# Uncomment and adjust if running on constrained hardware.

# POSTGRES_MEMORY_LIMIT=1g
# POSTGRES_CPU_LIMIT=1.0
# EVENT_STORE_MEMORY_LIMIT=512m
# API_MEMORY_LIMIT=512m
# API_CPU_LIMIT=0.5
# COLLECTOR_MEMORY_LIMIT=256m
# COLLECTOR_CPU_LIMIT=0.25
# MINIO_MEMORY_LIMIT=256m
# MINIO_CPU_LIMIT=0.25
# REDIS_MEMORY_LIMIT=256m
# REDIS_CPU_LIMIT=0.25
# UI_MEMORY_LIMIT=256m
# UI_CPU_LIMIT=0.25
